{
  "mcpServers": {
    "context7": {
      "autoApprove": ["resolve-library-id", "get-library-docs"],
      "timeout": 60,
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "transportType": "stdio"
    },
    "github": {
      "autoApprove": [
        "search_repositories",
        "get_file_contents",
        "search_code",
        "search_issues",
        "get_issue",
        "get_pull_request",
        "list_pull_requests",
        "get_pull_request_files",
        "get_pull_request_status",
        "get_pull_request_comments",
        "get_pull_request_reviews"
      ],
      "timeout": 60,
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "transportType": "stdio",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      }
    },
    "mcp-k8s-go": {
      "command": "mcp-k8s-go",
      "args": []
    }
  }
}
